    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 11,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "histogram_quantile(0.99, sum(rate(kafka_publish_latency_seconds_bucket[5m])) by (le))", "legendFormat": "Ingest -> Kafka (P99)", "refId": "A" },
        { "expr": "histogram_quantile(0.99, sum(rate(mongo_batch_insert_seconds_bucket[5m])) by (le))", "legendFormat": "Kafka -> Mongo (P99)", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(redis_projection_seconds_bucket[5m])) by (le))", "legendFormat": "Kafka -> Redis (P99)", "refId": "C" }
      ],
      "title": "Data Pipeline Latency (P99)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "percent" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 17,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "(\n  sum by (container_id) (\n    label_replace(\n      rate(container_cpu_cfs_throttled_periods_total{id=~\"/docker/[a-f0-9]+\"}[5m]),\n      \"container_id\",\n      \"$1\",\n      \"id\",\n      \".*/docker/([a-f0-9]{12}).*\"\n    )\n  )\n  /\n  sum by (container_id) (\n    label_replace(\n      rate(container_cpu_cfs_periods_total{id=~\"/docker/[a-f0-9]+\"}[5m]),\n      \"container_id\",\n      \"$1\",\n      \"id\",\n      \".*/docker/([a-f0-9]{12}).*\"\n    )\n  )\n) * 100 or vector(0)", "legendFormat": "ctr {{container_id}}", "refId": "A" }
      ],
      "title": "CPU Throttling (%)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "panels": [],
