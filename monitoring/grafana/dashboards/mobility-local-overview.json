      "targets": [
        { "expr": "sum by (container_id) (label_replace(rate(container_cpu_usage_seconds_total{id=~\"/docker/[a-f0-9]+\"}[5m]), \"container_id\", \"$1\", \"id\", \".*/docker/([a-f0-9]{12}).*\"))", "legendFormat": "ctr {{container_id}}", "refId": "A" }
