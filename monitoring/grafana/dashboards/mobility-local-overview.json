      "targets": [
        { "expr": "sum by (endpoint) (rate(query_vehicle_list_requests_total[5m]))", "legendFormat": "Query: {{endpoint}}", "refId": "A" },
        { "expr": "rate(ingest_requests_total[5m])", "legendFormat": "Ingest API", "refId": "B" }
      ],
      "title": "API Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "id": 7,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "rate(kafka_publish_success_total[5m])", "legendFormat": "Kafka OK", "refId": "A" },
        { "expr": "rate(mongo_consumer_messages_total[5m])", "legendFormat": "Mongo OK", "refId": "B" },
        { "expr": "rate(redis_projection_updates_total[5m])", "legendFormat": "Redis OK", "refId": "C" }
