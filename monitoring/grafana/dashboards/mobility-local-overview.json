    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "sum by (container_id) (label_replace(container_memory_working_set_bytes{id=~\"/docker/[a-f0-9]+\"}, \"container_id\", \"$1\", \"id\", \".*/docker/([a-f0-9]{12}).*\"))", "legendFormat": "ctr {{container_id}}", "refId": "A" }
      ],
      "title": "Container Memory",
      "type": "timeseries"
