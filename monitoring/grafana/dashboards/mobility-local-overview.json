      "targets": [
        { "expr": "100 * sum by (namespace, persistentvolumeclaim) (kubelet_volume_stats_used_bytes{namespace=~\"$namespace\"}) / sum by (namespace, persistentvolumeclaim) (kubelet_volume_stats_capacity_bytes{namespace=~\"$namespace\"})", "legendFormat": "K8s PVC: {{persistentvolumeclaim}}", "refId": "A" }
      ],
      "title": "Disk / PVC Usage (K8s 전용 지표)",
      "type": "timeseries"
    }
