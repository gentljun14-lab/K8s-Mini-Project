      "id": 18,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "sum by (container_id) (label_replace(changes(container_start_time_seconds{id=~\"/docker/[a-f0-9]+\"}[1h]), \"container_id\", \"$1\", \"id\", \".*/docker/([a-f0-9]{12}).*\"))", "legendFormat": "ctr {{container_id}}", "refId": "A" }
      ],
      "title": "Pod / Container Restarts (1h)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "panels": [],
      "title": "Resource Usage & Infrastructure",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
